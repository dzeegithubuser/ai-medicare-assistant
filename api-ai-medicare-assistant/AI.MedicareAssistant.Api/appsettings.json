{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${MYSQL_SERVER};Port=3306;Database=ai_medicare_assistant;User=${MYSQL_USER};Password=${MYSQL_PASSWORD};",
    "MongoDb": "mongodb://${MONGO_USER}:${MONGO_PASSWORD}@${MONGO_SERVER}:27017"
  },
  "MongoDb": {
    "DatabaseName": "ai_medicare_assistant"
  },
  "Jwt": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "AI.MedicareAssistant",
    "Audience": "AI.MedicareAssistant.Client",
    "ExpiryHours": 24
  },
  "AiProvider": "OpenAI",
  "OpenAI": {
    "ApiKey": "${OPENAI_API_KEY}",
    "Model": "${OPENAI_MODEL}"
  },
  "Anthropic": {
    "ApiKey": "${ANTHROPIC_API_KEY}",
    "Model": "${ANTHROPIC_MODEL}",
    "BaseUrl": "https://api.anthropic.com/v1/",
    "MaxTokens": 4000
  },
  "CMS": {
    "MedicarePartDSpendingUrl": "https://data.cms.gov/resource/7jry-e56r.json"
  },
  "Google": {
    "PlacesApiKey": "${GOOGLE_PLACES_API_KEY}"
  },
  "FinancialPlanner": {
    "BaseUrl": "${FP_BASE_URL}",
    "AuthToken": "${FP_AUTH_TOKEN}"
  },
  "Email": {
    "Host": "smtp.1and1.com",
    "Port": 587,
    "EnableSsl": true,
    "FromAddress": "support@aivante.com",
    "FromDisplayName": "AiVante",
    "Password": "${EMAIL_PASSWORD}",
    "TimeoutMs": 20000,
    "FrontendBaseUrl": "${EMAIL_FRONTEND_BASE_URL}"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://169.61.105.110:9600" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  }
}