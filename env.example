# ============================================================
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.
# ============================================================

# ── Database (MongoDB only) ──
MONGO_CONNECTION=mongodb://USER:PASSWORD@HOST:27017
MONGO_DB_NAME=ai_medicare_assistant

# ── JWT ──
JWT_SECRET=change-me-at-least-32-chars-long!

# ── AI Provider (OpenAI, Anthropic, or Gemini) ──
AI_PROVIDER=OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/
ANTHROPIC_MAX_TOKENS=4000
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/
GEMINI_MAX_OUTPUT_TOKENS=4000

# ── CORS ──
CORS_ALLOWED_ORIGINS_0=http://localhost:4200
CORS_ALLOWED_ORIGINS_1=http://localhost:9600

# ── Financial Planner API ──
FP_BASE_URL=http://HOST:8080/NewFinancialPlanner/api/v1
FP_AUTH_TOKEN=Basic BASE64_ENCODED_CREDENTIALS

# ── Email / SMTP ──
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_ENABLE_SSL=true
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_DISPLAY_NAME=AppName
EMAIL_PASSWORD=smtp-password
EMAIL_TIMEOUT_MS=20000
EMAIL_FRONTEND_BASE_URL=http://localhost:4200

# ── CMS ──
CMS_MEDICARE_PART_D_SPENDING_URL=https://data.cms.gov/resource/7jry-e56r.json
